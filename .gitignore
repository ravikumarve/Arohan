# ============================================
# AROHAN Project - .gitignore
# ============================================

# ============================================
# Project-Specific Exclusions
# ============================================
# Agent configuration and planning documents
AGENTS.md
# Copied agent files from agency-agents
agents/

# ============================================
# Python/FastAPI Exclusions
# ============================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
.venv/
ENV/
env.bak/
venv.bak/

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# Environment files (contains sensitive data)
.env
.env.local
.env.*.local
config/.env
config/.env.*

# Distribution / packaging
dist/
build/
*.egg-info/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.manifest
*.spec

# Testing and coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Database files
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal

# ============================================
# Docker Exclusions
# ============================================
# Docker volumes and temporary files
docker-volumes/
*.dockerfile
docker-compose.override.yml

# ============================================
# OS-Specific Files
# ============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory
.Trash-*
*~
.nfs*

# ============================================
# Log Files
# ============================================
*.log
logs/
*.log.*
log/

# ============================================
# Temporary Files
# ============================================
*.tmp
*.temp
tmp/
temp/
*.bak
*.backup
*.cache

# ============================================
# Audio and Media Files (Development)
# ============================================
# Test audio fixtures (keep only in tests/fixtures/audio/)
tests/fixtures/audio/*.wav
tests/fixtures/audio/*.mp3
tests/fixtures/audio/*.m4a

# ============================================
# AI/ML Model Files
# ============================================
# Local model weights and checkpoints
models/
*.pt
*.pth
*.onnx
*.bin
*.safetensors
checkpoints/

# ============================================
# RabbitMQ and Redis Data
# ============================================
# Message queue and cache data
rabbitmq_data/
redis_data/
*.rdb

# ============================================
# Security and Secrets
# ============================================
# SSH keys and certificates
*.pem
*.key
*.crt
*.p12
*.pfx
id_rsa*
id_ed25519*

# API keys and tokens (backup files)
*_secret.txt
*_key.txt
credentials.json
service-account.json

# ============================================
# Node.js (Next.js Dashboard)
# ============================================
# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build outputs
.next/
out/
build/
.vercel/

# ============================================
# Miscellaneous
# ============================================
# Archive files
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# Lock files (optional - uncomment if you want to ignore them)
# package-lock.json
# yarn.lock
# poetry.lock
