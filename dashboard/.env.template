# AROHAN Dashboard Environment Variables

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_API_TIMEOUT=30000

# Authentication
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3001

# Security
NEXT_PUBLIC_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_ERROR_REPORTING=true

# Development
NODE_ENV=development
NEXT_PUBLIC_DEBUG=true

# Production (uncomment for production)
# NEXT_PUBLIC_API_URL=https://api.arohan.com
# NEXT_PUBLIC_WS_URL=wss://api.arohan.com
# NEXTAUTH_URL=https://dashboard.arohan.com
# NEXTAUTH_SECRET=your-production-secret-key
# NEXT_PUBLIC_ALLOWED_ORIGINS=https://dashboard.arohan.com
# NODE_ENV=production
# NEXT_PUBLIC_DEBUG=false
