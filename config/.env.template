# RabbitMQ Configuration
RABBITMQ_USER=arohan
RABBITMQ_PASSWORD=rabbitmq_dev
RABBITMQ_VHOST=/arohan
RABBITMQ_URL=amqp://arohan:rabbitmq_dev@localhost:5672//arohan

# JWT Configuration
JWT_SECRET_KEY=dev_secret_change_in_production
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# External API Keys
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+91XXXXXXXXXX

META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_PHONE_NUMBER_ID=your_meta_phone_number_id
META_ACCESS_TOKEN=your_meta_access_token
META_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token

BHASHINI_API_KEY=your_bhashini_api_key
