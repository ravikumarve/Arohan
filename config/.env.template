# Database Configuration
POSTGRES_USER=arohan
POSTGRES_PASSWORD=arohan_dev
POSTGRES_DB=arohan
DATABASE_URL=postgresql+asyncpg://arohan:arohan_dev@localhost:5432/arohan

# Redis Configuration
REDIS_PASSWORD=redis_dev
