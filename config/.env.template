OPENAI_API_KEY=your_openai_api_key

PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=arohan-candidates
PINECONE_ENVIRONMENT=us-east-1-aws

# Application Configuration
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
WORKERS=4

# Celery Configuration
CELERY_BROKER_URL=amqp://arohan:rabbitmq_dev@localhost:5672//arohan
CELERY_RESULT_BACKEND=redis://:redis_dev@localhost:6379/0
CELERY_TASK_ACKS_LATE=true
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_WORKER_CONCURRENCY=8

# Audio Processing
AUDIO_MAX_DURATION_SECONDS=300
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
SUPPORTED_AUDIO_FORMATS=wav,mp3,m4a,ogg

# Performance Configuration
CACHE_TTL_SECONDS=3600
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
REQUEST_TIMEOUT_SECONDS=30

# Security
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
ALLOWED_HOSTS=localhost,127.0.0.1
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
HEALTH_CHECK_INTERVAL_SECONDS=30

# Dashboard Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NODE_ENV=development